# Crucible environment variables
# Copy this file to .env and fill in values (never commit .env to git)

# ── GitHub PR comment integration ────────────────────────────────────────────
# Required for: crucible attack --github-comment
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPOSITORY=owner/repo
PR_NUMBER=123

# ── Web dashboard auth ────────────────────────────────────────────────────────
# Optional: set to require X-Crucible-Token header on all /api/* endpoints
# If unset, the API is unauthenticated (localhost only is still safer than no key)
CRUCIBLE_API_KEY=change-me-to-a-random-secret

# ── Trace storage ─────────────────────────────────────────────────────────────
# Directory where .crucible trace files and darwin_state.json are written
# Default: traces/  (relative to cwd)
# CRUCIBLE_TRACES_DIR=traces
