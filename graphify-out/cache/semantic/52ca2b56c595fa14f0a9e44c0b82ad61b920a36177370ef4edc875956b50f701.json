{"nodes": [{"id": "crucible_readme_full_reference", "label": "Crucible Full Reference Documentation", "file_type": "document", "source_file": "crucible/README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "crucible_readme_attack_timing", "label": "Attack Type: timing", "file_type": "concept", "source_file": "crucible/README.md", "source_location": "Attack types table", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "crucible_readme_attack_env", "label": "Attack Type: env", "file_type": "concept", "source_file": "crucible/README.md", "source_location": "Attack types table", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "crucible_readme_attack_reorder", "label": "Attack Type: reorder", "file_type": "concept", "source_file": "crucible/README.md", "source_location": "Attack types table", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "crucible_readme_attack_network", "label": "Attack Type: network", "file_type": "concept", "source_file": "crucible/README.md", "source_location": "Attack types table", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "crucible_readme_attack_dependency", "label": "Attack Type: dependency", "file_type": "concept", "source_file": "crucible/README.md", "source_location": "Attack types table", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "crucible_readme_resilience_score", "label": "Resilience Score (0\u2013100, Grades A\u2013F)", "file_type": "concept", "source_file": "crucible/README.md", "source_location": "Resilience score section", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Four weighted components: survival rate (40%), blast containment (25%), recovery speed (20%), coverage breadth (15%). Scores stale after 30 days. Grades A>=90, B>=75, C>=60, D>=40, F<40."}, {"id": "crucible_readme_agent_fitness", "label": "Agent Fitness Scoring Mechanism", "file_type": "concept", "source_file": "crucible/README.md", "source_location": "Evolutionary mechanics section", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Fitness 0-100. Agents that trigger failures gain fitness; those finding nothing lose it. Below fitness 20 after 5+ attempts -> extinct, logged to failure cemetery."}, {"id": "crucible_readme_shadow_agents", "label": "Shadow Agents (--shadow flag)", "file_type": "concept", "source_file": "crucible/README.md", "source_location": "Shadow agents section", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Every production agent spawns a shadow running alternative mutations on a copy of the target. Shadow never touches the real target. If shadow trigger rate exceeds production by 20% for 3+ consecutive runs, shadow is promoted and the event is logged."}, {"id": "crucible_readme_replayable_traces", "label": "Replayable Traces (.crucible JSON format)", "file_type": "concept", "source_file": "crucible/README.md", "source_location": "Replayable traces section", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Every run writes a .crucible JSON file to traces/. Core data artifact \u2014 scoring, patterns, evolution are all derived from traces. Traces are reproducible and shareable for postmortems."}, {"id": "crucible_readme_github_pr_integration", "label": "GitHub PR Comment Integration", "file_type": "concept", "source_file": "crucible/README.md", "source_location": "GitHub PR comment section", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "crucible_readme_web_dashboard", "label": "Web Dashboard (FastAPI + uvicorn)", "file_type": "concept", "source_file": "crucible/README.md", "source_location": "Web dashboard section", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "crucible_readme_playwright_integration", "label": "Playwright Test Suite Integration", "file_type": "concept", "source_file": "crucible/README.md", "source_location": "Playwright integration section", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "crucible_readme_runner_orchestrator", "label": "runner.py \u2014 Single Orchestration Layer", "file_type": "rationale", "source_file": "crucible/README.md", "source_location": "Architecture principles section", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "runner.py is the only file that knows about all layers. Engine, agents, scorer, and memory do not import each other \u2014 only runner.py orchestrates them. This is an explicit architectural constraint."}, {"id": "crucible_readme_demo_mode", "label": "Demo Mode (create_demo_target)", "file_type": "concept", "source_file": "crucible/README.md", "source_location": "Architecture principles section", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Demo mode always works without any real pipeline. create_demo_target() produces a realistic synthetic target. Tests use this to enable CI without real workflow files."}, {"id": "crucible_readme_roadmap", "label": "Crucible Roadmap (v0.1 through v1.0)", "file_type": "document", "source_file": "crucible/README.md", "source_location": "Roadmap section", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "crucible_readme_darwin_runtime", "label": "Darwin Runtime (v1.0 roadmap target)", "file_type": "concept", "source_file": "crucible/README.md", "source_location": "Roadmap section", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "v1.0 goal: self-evolving attack strategies, full evolutionary agent infrastructure. Extends current fitness/extinction mechanics to auto